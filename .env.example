# Database — Railway injects this automatically when you add the PostgreSQL plugin
DATABASE_URL=postgresql://user:password@host:5432/urlshortener

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# The public base URL used to construct short links (no trailing slash)
BASE_URL=http://localhost:3000

# Allowed CORS origin for the React client
CLIENT_URL=http://localhost:5173
